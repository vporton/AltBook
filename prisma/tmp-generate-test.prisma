generator client {
  provider   = "prisma-client-js"
  output     = "/tmp/altbook-prisma-client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Author {
  id            String    @id @default(cuid())
  twitterId     String    @unique
  twitterHandle String    @unique
  displayName   String
  avatarUrl     String?
  posts         Post[]
  comments      Comment[]
  createdTopics Topic[]   @relation("TopicCreator")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Topic {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  createdByAuthorId String?
  createdByAuthor   Author?  @relation("TopicCreator", fields: [createdByAuthorId], references: [id], onDelete: SetNull)
  posts             Post[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([createdAt])
  @@index([createdByAuthorId])
}

model Post {
  id          String               @id @default(cuid())
  topicId     String
  topic       Topic                @relation(fields: [topicId], references: [id], onDelete: Restrict)
  authorId    String
  author      Author               @relation(fields: [authorId], references: [id], onDelete: Restrict)
  title       String
  slug        String               @unique
  body        String
  status      PublicationStatus    @default(PENDING)
  links       Json                 @default("[]")
  publishedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  comments    Comment[]
  decisions   ModerationDecision[]

  @@index([status, publishedAt])
  @@index([topicId, status, publishedAt])
  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id          String               @id @default(cuid())
  postId      String
  post        Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?             @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]            @relation("CommentReplies")
  authorId    String
  author      Author               @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body        String
  status      PublicationStatus    @default(PENDING)
  links       Json                 @default("[]")
  publishedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  decisions   ModerationDecision[]

  @@index([postId, status, publishedAt])
  @@index([parentId, status, publishedAt])
  @@index([authorId])
  @@index([createdAt])
}

model ModerationDecision {
  id          String   @id @default(cuid())
  contentKind String
  provider    String
  model       String
  outcome     String
  score       Float?
  reason      String
  links       Json     @default("[]")
  categories  Json     @default("[]")
  rawResponse Json?
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([contentKind, outcome])
  @@index([postId])
  @@index([commentId])
}
