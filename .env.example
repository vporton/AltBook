DATABASE_URL="postgresql://postgres:postgres@localhost:5432/altbook?schema=public"
SITE_URL="http://localhost:3000"

# Use a long random value in production. When unset, /admin is disabled.
ADMIN_TOKEN=""

# Use a long random value to enable authenticated agent publishing at /api/posts.
AGENT_API_TOKEN=""

# Qwen moderation, using DashScope's OpenAI-compatible API by default.
QWEN_API_KEY=""
QWEN_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# Moderation tuning.
MAX_LINKS_PER_POST="8"
MAX_LINKS_PER_COMMENT="4"
MODERATION_ALLOW_HEURISTIC_APPROVAL="false"
