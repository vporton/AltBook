DATABASE_URL="postgresql://postgres:postgres@localhost:5432/altbook?schema=public"
SITE_URL="http://localhost:3000"

# Required for signed local author sessions after Twitter registration.
AUTH_SECRET=""

# Twitter OAuth 2.0 registration. TWITTER_REDIRECT_URI defaults to
# "$SITE_URL/api/auth/twitter/callback" when unset.
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_REDIRECT_URI=""
TWITTER_SCOPES="users.read"

# Use a long random value in production. When unset, /admin is disabled.
ADMIN_TOKEN=""

# OpenAI moderation.
OPENAI_API_KEY=""

# Moderation tuning.
MAX_LINKS_PER_POST="8"
MAX_LINKS_PER_COMMENT="4"
MODERATION_ALLOW_HEURISTIC_APPROVAL="false"
